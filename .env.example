VITE_ENABLE_ADS=false
VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# Add real ad slot IDs where AdSlot is used in code.

# Optional override for contact form endpoint.
VITE_CONTACT_FORM_ENDPOINT=/api/contact

# Server-side contact email delivery (Vercel env vars)
RESEND_API_KEY=re_xx
# Optional recipient override (defaults to patrickpark208@gmail.com)
CONTACT_TO_EMAIL=you@example.com
# Optional sender override. Must be verified in Resend for production usage.
CONTACT_FROM_EMAIL=Tarkle Contact <onboarding@resend.dev>

# Optional rate limit controls for /api/contact
CONTACT_RATE_LIMIT_MAX=3
CONTACT_RATE_LIMIT_WINDOW_MS=900000
