{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/((?!api/|@vite/|@react-refresh|src/|node_modules/|.*\\..*).*)",
      "dest": "/index.html"
    }
  ]
}
